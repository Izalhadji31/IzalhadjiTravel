APP_NAME="ASR GO"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=asr_go
DB_USERNAME=root
DB_PASSWORD=

# Session & Queue
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# Midtrans Payment (sandbox by default)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_ENVIRONMENT=sandbox
MIDTRANS_ENABLE_PAY_LATER=true
MIDTRANS_ENABLE_INSTALLMENT=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# WhatsApp (Fonnte)
WHATSAPP_GATEWAY=fonnte
WHATSAPP_API_KEY=
WHATSAPP_API_URL=https://api.fonnte.com/v1

# Mail (SMTP example for Mailtrap / Gmail / Sendinblue)
# If MAIL_USERNAME and MAIL_PASSWORD are left empty, the app will automatically fall back to the log driver.
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@asrgo.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional: uncomment for Gmail/Sendinblue
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls
